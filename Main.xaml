<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trap Loader v1.1"
        Height="700" Width="1136"
        MinHeight="600" MinWidth="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        Background="#0d1117"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ==================== DARK SCROLLBAR STYLE ==================== -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="0,2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False"
                                   ViewportSize="1">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter CanContentScroll="False" Margin="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       HorizontalAlignment="Right"
                                       Width="10"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== CONTEXT MENU STYLE ==================== -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== MENU ITEM STYLE ==================== -->
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="menuItemBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="1" Text="▶"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="8"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   Placement="Right"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="0,6">
                                    <ItemsPresenter Margin="0" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="menuItemBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== SEPARATOR STYLE ==================== -->
        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,5"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}"
                                Margin="{TemplateBinding Margin}"
                                SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== SEPARATOR STYLE  ==================== -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder"
                                Background="Transparent"
                                Padding="16,10"
                                Cursor="Hand"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextBlock.FontWeight="SemiBold"
                                                  TextBlock.FontSize="13"/>
                                <Border x:Name="indicator"
                                        Height="2"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,0,-10"
                                        CornerRadius="1"
                                        Background="Transparent"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="indicator" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Background="{DynamicResource SurfaceBrush}" ClipToBounds="True">
                                <Border DockPanel.Dock="Right" Background="Transparent" Padding="12,0,12,0" VerticalAlignment="Center" MaxWidth="280">
                                    <DockPanel>
                                        <TextBox x:Name="searchTextBox" MinWidth="100" VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                                        <Button x:Name="selectNoneButton" Content="☐" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource TextSecondaryBrush}" Padding="8,5" Margin="0,0,6,0" ToolTip="Deselect all clients" FontSize="12" Cursor="Hand" DockPanel.Dock="Right"/>
                                        <Border Background="{DynamicResource SurfaceLightBrush}" CornerRadius="10" Padding="10,3" VerticalAlignment="Center" DockPanel.Dock="Right">
                                            <TextBlock x:Name="selectedClientCountLbl" Text="0 selected" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button x:Name="selectAllButton" Content="☑" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource TextSecondaryBrush}" Padding="8,5" Margin="0,0,3,0" ToolTip="Select all clients (Ctrl+A)" FontSize="12" Cursor="Hand" DockPanel.Dock="Right"/>
                                        <Button x:Name="refreshButton" Content="↻" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource TextPrimaryBrush}" Padding="12,5" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" DockPanel.Dock="Right"/>
                                        <Button x:Name="searchButton" Content="Search" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Foreground="{DynamicResource TextPrimaryBrush}" Padding="12,5" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" DockPanel.Dock="Right"/>
                                    </DockPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" IsItemsHost="True" Margin="0"/>
                            </DockPanel>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="itemBorder"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="4,8"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#1a2744"/>
                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="itemBorder"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      IsHitTestVisible="False"/>

                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="{TemplateBinding Padding}"
                                             VerticalAlignment="Center"
                                             Visibility="Hidden"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             Background="Transparent"
                                             Foreground="{TemplateBinding Foreground}"
                                             BorderThickness="0"/>

                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="{DynamicResource TextSecondaryBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Margin="0"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="30"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledBrush}"/>
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== RADIO BUTTON STYLE ==================== -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="18" Height="18" VerticalAlignment="Center">
                                <Ellipse x:Name="outerCircle"
                                         Width="18" Height="18"
                                         Stroke="{DynamicResource BorderBrush}"
                                         StrokeThickness="1.5"
                                         Fill="{DynamicResource SurfaceBrush}"/>
                                <Ellipse x:Name="innerDot"
                                         Width="8" Height="8"
                                         Fill="{DynamicResource PrimaryBrush}"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outerCircle" Property="Stroke" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="outerCircle" Property="Fill" Value="#1a2744"/>
                                <Setter TargetName="innerDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outerCircle" Property="Stroke" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== PRIMARY BUTTON ==================== -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="btnContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="#2d2d30"/>
                                <Setter TargetName="btnBorder" Property="TextElement.Foreground" Value="#555555"/>
                                <Setter TargetName="btnContent" Property="TextBlock.Foreground" Value="#555555"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

        <!-- ==================== DANGER BUTTON ==================== -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="btnContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#8b1a1a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="#2d2d30"/>
                                <Setter TargetName="btnBorder" Property="TextElement.Foreground" Value="#555555"/>
                                <Setter TargetName="btnContent" Property="TextBlock.Foreground" Value="#555555"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== SUCCESS BUTTON ==================== -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="btnContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#156b2d"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="#2d2d30"/>
                                <Setter TargetName="btnBorder" Property="TextElement.Foreground" Value="#555555"/>
                                <Setter TargetName="btnContent" Property="TextBlock.Foreground" Value="#555555"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== OUTLINE BUTTON ==================== -->
        <Style x:Key="OutlineButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="btnContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#2d2d30"/>
                                <Setter TargetName="btnBorder" Property="TextElement.Foreground" Value="#555555"/>
                                <Setter TargetName="btnContent" Property="TextBlock.Foreground" Value="#555555"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== WARNING BUTTON ==================== -->
        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
            <Setter Property="Foreground" Value="#0d1117"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter x:Name="btnContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#b8860b"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#996600"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="#2d2d30"/>
                                <Setter TargetName="btnBorder" Property="TextElement.Foreground" Value="#555555"/>
                                <Setter TargetName="btnContent" Property="TextBlock.Foreground" Value="#555555"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== SMALL ICON BUTTON (for toolbar actions) ==================== -->
        <Style x:Key="SmallIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="btnContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="checkBorder"
                                    Width="18" Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="checkMark"
                                      Data="M 3 8 L 7 12 L 14 4"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Stretch="Uniform"
                                      Width="10" Height="10"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ==================== LABELED CHECKBOX (with text) ==================== -->
        <Style x:Key="LabeledCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBorder"
                                    Width="18" Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True"
                                    VerticalAlignment="Center">
                                <Path x:Name="checkMark"
                                      Data="M 3 8 L 7 12 L 14 4"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Stretch="Uniform"
                                      Width="10" Height="10"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== TOP BAR ==================== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Trap Loader" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="4"
                            Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.1" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="statusIndicator" Width="8" Height="8"
                             Fill="{DynamicResource DangerBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="connectionStatusText" Text="Disconnected"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== TAB CONTROL ==================== -->
        <TabControl x:Name="tabControl" Grid.Row="1"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderThickness="0"
                    Padding="0"
                    SelectionChanged="TabControl_SelectionChanged"
                    d:SelectedIndex="0">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                    <Setter Property="Margin" Value="0"/>
                </Style>
            </TabControl.Resources>

            <!-- ==================== CLIENTS TAB ==================== -->
            <TabItem Header="Clients" x:Name="clientsTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Client list -->
                    <Border Grid.Row="0" Margin="16,12"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}">
                        <ListView x:Name="clientList" SelectionMode="Extended"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionChanged="ClientList_SelectionChanged">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Execution Mode"
                                              IsEnabled="False"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <MenuItem x:Name="ctxDropToDisk" Header="💾  Drop to Disk"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              Click="CtxExecMode_Click"
                                              ToolTip="Write file to disk then execute"/>
                                    <MenuItem x:Name="ctxInMemory" Header="⚡  In-Memory"
                                              IsCheckable="True"
                                              Click="CtxExecMode_Click"
                                              ToolTip="Load directly into memory — no disk write"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView AllowsColumnReorder="True">
                                    <GridViewColumn Header="" Width="45">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          Focusable="False"
                                                          IsThreeState="False"
                                                          Checked="ClientCheckBox_Changed"
                                                          Unchecked="ClientCheckBox_Changed"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Name" Width="140" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="OS Version" Width="130" DisplayMemberBinding="{Binding OSVersion}"/>
                                    <GridViewColumn Header="Wallet" Width="160" DisplayMemberBinding="{Binding CryptoWallet}"/>
                                    <GridViewColumn Header="Machine Name" Width="140" DisplayMemberBinding="{Binding MachineName}"/>
                                    <GridViewColumn Header="Antivirus" Width="180" DisplayMemberBinding="{Binding AntivirusProducts}"/>
                                    <GridViewColumn Header="Admin" Width="70" DisplayMemberBinding="{Binding IsAdmin}"/>
                                    <GridViewColumn Header="Webcam" Width="70" DisplayMemberBinding="{Binding HasWebcam}"/>
                                    <GridViewColumn Header="Active Window" Width="160" DisplayMemberBinding="{Binding ActiveWindow}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- Bottom bar with status + send -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <Border Background="{DynamicResource SurfaceLightBrush}"
                                CornerRadius="6" Padding="12,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Status:" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="statusTextBox" Grid.Column="1"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         Style="{x:Null}"
                                         VerticalAlignment="Center"
                                         FontSize="12"/>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== AUTO TASKS TAB ==================== -->
            <TabItem Header="Auto Tasks" x:Name="autoTasksTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Task List -->
                    <Border Grid.Row="0" Margin="16,16,16,12"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}">
                        <ListView x:Name="autoTasksList" SelectionMode="Multiple"
                                  Background="Transparent"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="🚀  Start XMRig Miner on Clients"
                                              x:Name="ctxStartMiner"
                                              Click="StartMinerOnClients_Click"
                                              ToolTip="Deploy XMRig to all connected clients and create auto task"/>
                                    <Separator/>
                                    <MenuItem Header="Edit Miner Config (selected)"
                                              x:Name="ctxEditMinerConfig"
                                              Click="EditAutoTaskMinerConfig_Click"
                                              ToolTip="Edit pool, wallet, worker for selected miner task"/>
                                    <Separator/>
                                    <MenuItem Header="Execution Mode"
                                              IsEnabled="False"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <MenuItem x:Name="ctxAutoDropToDisk" Header="💾  Drop to Disk"
                                              IsCheckable="True"
                                              IsChecked="True"
                                              Click="CtxAutoExecMode_Click"
                                              ToolTip="Write file to disk then execute"/>
                                    <MenuItem x:Name="ctxAutoInMemory" Header="⚡  In-Memory"
                                              IsCheckable="True"
                                              Click="CtxAutoExecMode_Click"
                                              ToolTip="Load directly into memory — no disk write"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView AllowsColumnReorder="True">
                                    <GridViewColumn Header="" Width="45">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          Focusable="False"
                                                          IsThreeState="False"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Name" Width="160" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Status" Width="160" DisplayMemberBinding="{Binding Status}"/>
                                    <GridViewColumn Header="Mode" Width="120" DisplayMemberBinding="{Binding ExecModeDisplay}"/>
                                    <GridViewColumn Header="File Path" Width="240" DisplayMemberBinding="{Binding FilePath}"/>
                                    <GridViewColumn Header="Run Info" Width="300" DisplayMemberBinding="{Binding RunInfo}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- Action Buttons -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{DynamicResource SurfaceLightBrush}"
                                    CornerRadius="6" Padding="12,6" Margin="0,0,12,0">
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center">
                                    <Run Text="ℹ️"/>
                                    <Run Text="  Auto tasks run when new clients connect. Toggle execution mode per task."/>
                                </TextBlock>
                            </Border>

                            <Button Grid.Column="1" Content="➕ Add Task"
                                    Click="AddAutoTaskButton_Click"
                                    Style="{StaticResource SuccessButton}"
                                    Margin="0,0,6,0"/>

                            <Button Grid.Column="2" Content="🔄 Toggle"
                                    Click="ToggleAutoTaskButton_Click"
                                    Style="{StaticResource OutlineButton}"
                                    Margin="0,0,6,0"
                                    ToolTip="Enable / Disable selected tasks"/>

                            <Button Grid.Column="3" Content="⚡ Mode"
                                    Click="ToggleAutoTaskModeButton_Click"
                                    Style="{StaticResource WarningButton}"
                                    Margin="0,0,6,0"
                                    ToolTip="Toggle selected tasks between In-Memory and Drop-to-Disk"/>

                            <Button Grid.Column="4" Content="📋 View Log"
                                    Click="ViewTaskLogButton_Click"
                                    Style="{StaticResource OutlineButton}"
                                    Margin="0,0,6,0"/>

                            <Button Grid.Column="5" Content="🗑️ Remove"
                                    Click="RemoveAutoTaskButton_Click"
                                    Style="{StaticResource DangerButton}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== LOGS TAB ==================== -->
            <TabItem Header="Logs" x:Name="logsTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <Border Margin="16" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBox x:Name="logTextBox"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Background="Transparent"
                                         Foreground="#c9d1d9"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Mono, Consolas, 'Courier New', monospace"
                                         FontSize="13"
                                         Padding="16,12"
                                         VerticalScrollBarVisibility="Disabled"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Style="{x:Null}"
                                         CaretBrush="White"
                                         MinHeight="200"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ==================== PLUGINS TAB ==================== -->
            <TabItem Header="Plugins" x:Name="pluginsTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="pluginListPanel" Margin="16">

                            <TextBlock Text="Loaded Plugins"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="pluginCountLabel"
                                       Text="0 plugin(s) available. Right-click a client to launch."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,16"/>

                            <StackPanel x:Name="pluginCardsPanel"/>

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button x:Name="reloadPluginsButton"
                                        Content="🔄  Reload Plugins"
                                        Click="ReloadPluginsButton_Click"
                                        Style="{StaticResource OutlineButton}"
                                        Margin="0,0,8,0"/>
                                <Button x:Name="openPluginsFolderButton"
                                        Content="📂  Open Plugins Folder"
                                        Click="OpenPluginsFolderButton_Click"
                                        Style="{StaticResource OutlineButton}"/>
                            </StackPanel>

                            <Border Background="{DynamicResource SurfaceLightBrush}"
                                    CornerRadius="6"
                                    Padding="16,12"
                                    Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="How to add plugins"
                                               FontWeight="SemiBold" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               LineHeight="20">
                                        <Run Text="1. Create a class library (.dll) implementing"/>
                                        <Run Text="IServerPlugin" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <LineBreak/>
                                        <Run Text="2. Drop the .dll into the"/>
                                        <Run Text="Plugins/" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <Run Text="folder next to the application"/>
                                        <LineBreak/>
                                        <Run Text="3. Click 'Reload Plugins' or restart the application"/>
                                        <LineBreak/>
                                        <Run Text="4. Right-click a connected client to launch your plugin"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ==================== NETWORK TAB ==================== -->
            <TabItem Header="Network" x:Name="networkTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  Padding="0,0,4,0">
                        <StackPanel Margin="28,20,32,40">

                            <Button x:Name="networkRefreshButton"
                                    Content="⟳ Refresh"
                                    Click="NetworkRefreshButton_Click"
                                    Style="{StaticResource OutlineButton}"
                                    Padding="18,8" FontSize="12"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,16"/>

                            <!-- ===== Public Identity Card ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🌍" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Public Identity" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Grid Margin="24,20,24,20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Public IPv4"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkPublicIpText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     Text="Loading..." FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkPublicIpText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Hostname"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkHostnameText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkHostnameText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Local Network Card ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🏠" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Local Network" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Grid Margin="24,20,24,20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Local IPv4"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkLocalIpText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkLocalIpText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Subnet Mask"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkSubnetText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkSubnetText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Default Gateway"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkGatewayText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkGatewayText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="DNS Servers"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkDnsText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkDnsText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ===== Active Adapter Card ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="{DynamicResource WarningBrush}"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🔌" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Active Adapter" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Grid Margin="24,20,24,20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="16"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Adapter Name"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkAdapterNameText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkAdapterNameText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="MAC Address"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkMacText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkMacText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Link Speed"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBox x:Name="networkSpeedText" Grid.Column="1"
                                                     Padding="10,8" FontSize="13" MinHeight="32"
                                                     VerticalContentAlignment="Center"
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                                     FontFamily="Consolas"
                                                     Background="{DynamicResource SurfaceLightBrush}"
                                                     BorderThickness="0"/>
                                            <Button Grid.Column="2" Tag="networkSpeedText" Click="CopyField_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="6,4" FontSize="11"
                                                    Content="Copy" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ==================== BUILDER TAB ==================== -->
            <TabItem Header="Builder" x:Name="builderTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="24,16,24,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ===== LEFT COLUMN — Connection Settings ===== -->
                            <Border Grid.Column="0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="8,8,0,0"
                                            Padding="20,12"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🌐" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Connection Settings" FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="20,16,20,20">
                                        <TextBlock Text="SERVER IP / HOSTNAME" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <TextBox x:Name="builderIpTextBox" Padding="12,10" Margin="0,0,0,14" FontSize="13"
                                                   MinHeight="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>

                                        <TextBlock Text="PORT" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <TextBox x:Name="builderPortTextBox" Padding="12,10" Margin="0,0,0,14" FontSize="13"
                                                   MinHeight="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>

                                        <TextBlock Text="PASSWORD" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="builderPasswordBox" Grid.Column="0" Padding="12,10" FontSize="13"
                                                         MinHeight="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                                        </Grid>
                                        <TextBlock Text="Minimum 12 characters · Used for authentication"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10" Margin="0,0,0,14" Opacity="0.7"/>

                                        <TextBlock Text="ENCRYPTION KEY (optional)" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="builderEncryptionKeyTextBox" Grid.Column="0"
                                                      FontFamily="Cascadia Mono, Consolas, monospace"
                                                      FontSize="13" Padding="12,10"
                                                      MinHeight="36" VerticalContentAlignment="Center"
                                                      HorizontalAlignment="Stretch"/>
                                            <Button Grid.Column="2" Content="Generate" Click="GenerateKeyButton_Click"
                                                    Style="{StaticResource OutlineButton}" Padding="14,8" FontSize="12"/>
                                        </Grid>
                                        <TextBlock Text="Optional · TLS replaces AES-GCM · Click Generate for random key"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10" Margin="0,4,0,0" Opacity="0.7"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ===== RIGHT COLUMN — Build Options + Output ===== -->
                            <Grid Grid.Column="2" Margin="0,0,0,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Border Background="{DynamicResource SurfaceLightBrush}"
                                                CornerRadius="8,8,0,0"
                                                Padding="20,12"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔧" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Build Options" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Margin="20,16,20,20">
                                            <Border Background="{DynamicResource SurfaceLightBrush}"
                                                    CornerRadius="6"
                                                    Padding="16,12"
                                                    Margin="0,0,0,16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox x:Name="builderSilentCheckBox"
                                                              Grid.Column="0"
                                                              Style="{StaticResource LabeledCheckBox}"
                                                              Content="Silent Mode"
                                                              FontWeight="SemiBold"
                                                              IsChecked="True"
                                                              VerticalAlignment="Top"
                                                              Margin="0,1,0,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="No console window or GUI popup. The stub runs completely invisible."
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="12,2,0,0"
                                                               LineHeight="16"/>
                                                </Grid>
                                            </Border>
                                            <Border Background="#0d1117"
                                                    CornerRadius="6"
                                                    Padding="14,10"
                                                    Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Target:" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="11" FontWeight="SemiBold" Width="70"/>
                                                        <TextBlock Grid.Column="1" Text=".NET Framework 4.7.2"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="11" FontFamily="Consolas"/>
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Compat:" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="11" FontWeight="SemiBold" Width="70"/>
                                                        <TextBlock Grid.Column="1" Text="Windows 10 1803+, Windows 11"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="11" FontFamily="Consolas"/>
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Output:" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="11" FontWeight="SemiBold" Width="70"/>
                                                        <TextBlock Grid.Column="1" Text="Single standalone EXE"
                                                                   Foreground="{DynamicResource SuccessBrush}"
                                                                   FontSize="11" FontFamily="Consolas" FontWeight="SemiBold"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        x:Name="builderGenerateButton"
                                                        Content="Generate PS1"
                                                        Click="BuilderGenerateButton_Click"
                                                        Style="{StaticResource OutlineButton}"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="16,12"
                                                        FontSize="13"/>
                                                <Button Grid.Column="2"
                                                        Content="Compile EXE"
                                                        Click="CompileExeButton_Click"
                                                        Style="{StaticResource PrimaryButton}"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="16,12"
                                                        FontSize="13"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource SurfaceLightBrush}"
                                                CornerRadius="8,8,0,0"
                                                Padding="20,12"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Build Output" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1"
                                                Margin="12,10,12,12"
                                                CornerRadius="6"
                                                Background="#0d1117"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1">
                                            <TextBox x:Name="builderOutputTextBox"
                                                     MinHeight="100"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     Background="Transparent"
                                                     Foreground="#c9d1d9"
                                                     BorderThickness="0"
                                                     FontFamily="Cascadia Mono, Consolas, monospace"
                                                     FontSize="11"
                                                     Padding="12,10"
                                                     Style="{x:Null}"
                                                     CaretBrush="White"
                                                     Text="Ready to generate stub..."/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ==================== THEMES TAB ==================== -->
            <TabItem Header="Themes" x:Name="themesTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  >
                        <StackPanel Margin="24,16,24,24">

                            <!-- Header -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,16"
                                    Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="8"
                                                Background="{DynamicResource PrimaryBrush}"
                                                VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="🎨" FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Appearance" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Choose a theme to personalize the panel"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource SurfaceLightBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6" Padding="12,6"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6"
                                                     Fill="{DynamicResource SuccessBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="currentThemeLabel"
                                                       Text="Dark"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Theme Cards Grid -->
                            <ItemsControl x:Name="themeCardsPanel"
                                          HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="cardBorder"
                                                Width="248" Height="232"
                                                Margin="0,0,16,16"
                                                CornerRadius="12"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                SnapsToDevicePixels="True"
                                                MouseLeftButtonUp="ThemeCard_Click"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                                         To="1.04" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CircleEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                                         To="1.04" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CircleEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                                         To="1.0" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CircleEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                                         To="1.0" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CircleEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Color Preview Strip -->
                                                <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                                        Background="{DynamicResource SurfaceLightBrush}"
                                                        Padding="0" Height="52"
                                                        BorderThickness="0,0,0,1"
                                                        BorderBrush="{DynamicResource BorderBrush}">
                                                    <Grid Margin="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{Binding PrimaryBrush}"
                                                                CornerRadius="6,0,0,6" Margin="0,0,2,0"/>
                                                        <Border Grid.Column="1" Background="{Binding SurfaceBrush}"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                CornerRadius="0" Margin="1,0"/>
                                                        <Border Grid.Column="2" Background="{Binding BackgroundBrush}"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                CornerRadius="0" Margin="1,0"/>
                                                        <Border Grid.Column="3" Background="{Binding BorderBrush}"
                                                                CornerRadius="0,6,6,0" Margin="2,0,0,0"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Content -->
                                                <Grid Grid.Row="1" Margin="14,12,14,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Theme Name -->
                                                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                                Margin="0,0,0,2">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="15" FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                        <Border x:Name="activeTag"
                                                                Background="{DynamicResource SuccessBrush}"
                                                                CornerRadius="3"
                                                                Padding="5,1"
                                                                Margin="8,0,0,0"
                                                                Visibility="Collapsed"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="Active"
                                                                       Foreground="#0d1117"
                                                                       FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Description -->
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,8"
                                                               LineHeight="16"/>

                                                    <!-- Color Swatches -->
                                                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom"
                                                                Margin="0,0,0,8">
                                                        <TextBlock Text="Palette"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="9" FontWeight="SemiBold"
                                                                   Margin="0,0,0,4"/>
                                                        <WrapPanel Orientation="Horizontal">
                                                            <Border Width="28" Height="28" CornerRadius="4"
                                                                    Background="{Binding PrimaryBrush}"
                                                                    Margin="0,0,4,4"
                                                                    ToolTip="Primary accent"/>
                                                            <Border Width="28" Height="28" CornerRadius="4"
                                                                    Background="{Binding SurfaceBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    Margin="0,0,4,4"
                                                                    ToolTip="Surface"/>
                                                            <Border Width="28" Height="28" CornerRadius="4"
                                                                    Background="{Binding BackgroundBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="1"
                                                                    Margin="0,0,4,4"
                                                                    ToolTip="Background"/>
                                                            <Border Width="28" Height="28" CornerRadius="4"
                                                                    Background="{Binding BorderBrush}"
                                                                    Margin="0,0,4,4"
                                                                    ToolTip="Border"/>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Footer bar -->
                                                <Border Grid.Row="2"
                                                        CornerRadius="0,0,12,12"
                                                        Padding="0,5"
                                                        Height="26">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceLightBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               FontSize="10" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Click to apply"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="✓ Active"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Info Box -->
                            <Border Background="{DynamicResource SurfaceLightBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,12"
                                    Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="20" Height="20" CornerRadius="5"
                                            Background="{DynamicResource PrimaryBrush}"
                                            VerticalAlignment="Top" Margin="0,0,10,0">
                                        <TextBlock Text="i" Foreground="White"
                                                   FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" LineHeight="20"
                                               VerticalAlignment="Center">
                                            <Run Text="Themes are applied instantly. Your selection is saved and restored on next launch."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ==================== SETTINGS TAB ==================== -->
            <TabItem Header="Settings" x:Name="settingsTab">
                <Grid Background="{DynamicResource BackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  Padding="0,0,4,0">
                        <StackPanel Margin="28,20,32,40">

                            <!-- ===== Header ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="24,18"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#000"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="4" Height="28"
                                            Background="{DynamicResource PrimaryBrush}"
                                            CornerRadius="2" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚙️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Server Settings" FontSize="20" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="6" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="settingsStatusIndicator" Width="8" Height="8"
                                                     Fill="{DynamicResource DangerBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="settingsStatusText" Text="Disconnected"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ===== Server Connection Card ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Server Connection" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Margin="24,20,24,20">

                                        <!-- Port row -->
                                        <TextBlock Text="Listen Port" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="listenportTextBox" Grid.Column="0"
                                                      Padding="12,10" FontSize="13" MinHeight="36"
                                                      VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                                            <Button x:Name="btnListenToggle" Grid.Column="2"
                                                    Content="▶ Start Listening"
                                                    Click="BtnListenToggle_Click"
                                                    Style="{StaticResource SuccessButton}"
                                                    Padding="22,9" FontSize="13" MinWidth="150"
                                                    VerticalAlignment="Center"/>
                                        </Grid>

                                        <Separator Margin="0,0,0,16"/>

                                        <!-- Password row -->
                                        <TextBlock Text="Server Password" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="HttpPasswordBox" Grid.Column="0"
                                                          Padding="12,10" FontSize="13" MinHeight="36"
                                                          VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                                            <Button Grid.Column="3" x:Name="setPasswordButton" Content="Set"
                                                    Click="SetPasswordButton_Click"
                                                    Style="{StaticResource PrimaryButton}" Padding="20,9" FontSize="12"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Minimum 12 characters. Used for client authentication on connect."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10" Margin="0,0,0,16" Opacity="0.6"/>

                                        <Separator Margin="0,0,0,16"/>

                                        <!-- Options -->
                                        <Border Background="{DynamicResource SurfaceLightBrush}"
                                                CornerRadius="8" Padding="18,14">
                                            <StackPanel>
                                                <CheckBox x:Name="chkAutoListen"
                                                          Style="{StaticResource LabeledCheckBox}"
                                                          Content="Listen for new connections on startup"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                          Margin="0,0,0,10"/>
                                                <CheckBox x:Name="chkShowPopup"
                                                          Style="{StaticResource LabeledCheckBox}"
                                                          Content="Show popup notification on new connection"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== Certificate Management Card ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="#E8A600"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🔒" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Certificate Management" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Margin="24,20,24,20">
                                        <Border Background="{DynamicResource SurfaceLightBrush}"
                                                CornerRadius="8" Padding="18,14" Margin="0,0,0,14">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse x:Name="certStatusDot" Width="10" Height="10"
                                                             Fill="#666" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" x:Name="certStatusText"
                                                               Text="Loading..."
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Grid>

                                                <TextBlock x:Name="certSubjectLabel"
                                                           Text=""
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="12" Margin="20,0,0,4"/>
                                                <TextBlock x:Name="certExpiryLabel"
                                                           Text=""
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="12" Margin="20,0,0,4"/>
                                                <TextBlock x:Name="certHashLabel"
                                                           Text=""
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" Margin="20,0,0,0" Opacity="0.7"/>
                                            </StackPanel>
                                        </Border>

                                        <Button x:Name="btnChangeCert" Content="Change Certificate"
                                                Click="BtnChangeCert_Click"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="18,9" FontSize="12"
                                                HorizontalAlignment="Left"/>
                                        <TextBlock Text="Changing the certificate invalidates all existing client stubs. You must rebuild and redistribute the client executable."
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="10" Margin="0,8,0,0" Opacity="0.7" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== Notifications Card (Telegram) ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="#2AABEE"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🔔" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Notifications" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Margin="24,20,24,20">
                                        <CheckBox x:Name="chkTelegramNotify"
                                                  Style="{StaticResource LabeledCheckBox}"
                                                  Content="Telegram notification on client connect"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Margin="0,0,0,16"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="Bot Token" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                                                <PasswordBox x:Name="telegramTokenBox" Padding="12,10" FontSize="13"
                                                             MinHeight="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Chat ID" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                                                <TextBox x:Name="telegramChatIdBox" Padding="12,10" FontSize="13"
                                                         MinHeight="36" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </Grid>

                                        <Button x:Name="btnTestTelegram" Content="Test Notification"
                                                Click="BtnTestTelegram_Click"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="18,9" FontSize="12"
                                                HorizontalAlignment="Left" Margin="0,14,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ===== Discord Rich Presence Card ===== -->
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.12" Color="#000"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="10,10,0,0"
                                            Padding="20,14"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="3" Height="18"
                                                    Background="#5865F2"
                                                    CornerRadius="1.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🎮" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Discord Rich Presence" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Margin="24,20,24,20">
                                        <Border Background="{DynamicResource SurfaceLightBrush}"
                                                CornerRadius="8" Padding="18,14">
                                            <StackPanel>
                                                <CheckBox x:Name="chkDiscordRpc"
                                                          Style="{StaticResource LabeledCheckBox}"
                                                          Content="Enable Discord Rich Presence"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                          Margin="0,0,0,12"
                                                          Checked="ChkDiscordRpc_Checked"
                                                          Unchecked="ChkDiscordRpc_Unchecked"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" x:Name="discordStatusDot" Width="8" Height="8"
                                                             Fill="#666" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" x:Name="discordStatusText"
                                                               Text="Inactive"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" x:Name="btnRecheckDiscord" Content="Reconnect"
                                                            Click="BtnRecheckDiscord_Click"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Padding="16,7" FontSize="11"
                                                            HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Changes are saved automatically when you close the panel or start the server."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" Opacity="0.4" HorizontalAlignment="Center" Margin="0,4,0,0"/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ==================== STATUS BAR ==================== -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="4" Padding="10,4" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Clients: " Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock x:Name="clientCountLbl" Text="0" Foreground="{DynamicResource PrimaryBrush}"
                                   FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="4" Padding="10,4" Margin="0,0,12,0">
                    <TextBlock x:Name="lastFileLbl" Text="Last file sent: None"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="4" Padding="10,4" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔌 " FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="activePluginCountLbl" Text="0 active"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="4" Padding="10,4" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️ " FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="autoTaskStatusLbl" Text="Auto: 0 tasks"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"/>

                <Border Grid.Column="6" Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="4" Padding="10,4">
                    <TextBlock x:Name="portLbl" Text="Port: —"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
