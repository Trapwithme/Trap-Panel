<Window x:Class="WpfApp.CertificateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Certificate Setup" Height="450" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="#E0E0E0"
        FontFamily="Consolas">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Server Certificate"
                   FontSize="18" FontWeight="Bold" Foreground="#569CD6"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="0" TextWrapping="Wrap"
                   Text="No certificate found. Create a new one or import an existing .pfx file.&#x0a;The certificate is used for TLS encryption and client authentication."
                   Foreground="#888" Margin="0,25,0,10"/>

        <TextBox Grid.Row="1" x:Name="txtDetails"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 Margin="0,5,0,5"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
            <Button x:Name="btnCreate" Content="Create New Certificate" Click="BtnCreate_Click" Width="200"/>
            <Button x:Name="btnImport" Content="Import .pfx File" Click="BtnImport_Click" Width="180"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Save and Continue" Click="BtnSave_Click" Width="160"
                    IsEnabled="False" Background="#0E639C"/>
            <Button x:Name="btnExit" Content="Exit" Click="BtnExit_Click" Width="100"
                    Background="#5A1D1D"/>
        </StackPanel>
    </Grid>
</Window>
