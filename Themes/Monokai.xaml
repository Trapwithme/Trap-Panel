<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryColor">#a6e22e</Color>
    <Color x:Key="PrimaryHoverColor">#8ccf1a</Color>
    <Color x:Key="PrimaryPressedColor">#72b80a</Color>
    <Color x:Key="SurfaceColor">#2d2a2e</Color>
    <Color x:Key="SurfaceLightColor">#3e3b40</Color>
    <Color x:Key="BorderColor">#4a474d</Color>
    <Color x:Key="TextPrimaryColor">#f8f8f2</Color>
    <Color x:Key="TextSecondaryColor">#a59f85</Color>
    <Color x:Key="DangerColor">#f92672</Color>
    <Color x:Key="DangerHoverColor">#e01a60</Color>
    <Color x:Key="SuccessColor">#a6e22e</Color>
    <Color x:Key="SuccessHoverColor">#8ccf1a</Color>
    <Color x:Key="BackgroundColor">#1e1c20</Color>
    <Color x:Key="DisabledColor">#4a474d</Color>
    <Color x:Key="WarningColor">#fd971f</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="{StaticResource SuccessHoverColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <Color x:Key="ButtonBgColor">#2d2a2e</Color>
    <Color x:Key="ButtonBgHoverColor">#3e3b40</Color>
    <Color x:Key="ButtonBorderColor">#4a474d</Color>

    <SolidColorBrush x:Key="ButtonBgBrush" Color="{StaticResource ButtonBgColor}"/>
    <SolidColorBrush x:Key="ButtonBgHoverBrush" Color="{StaticResource ButtonBgHoverColor}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ButtonBorderColor}"/>
</ResourceDictionary>
